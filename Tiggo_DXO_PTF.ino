 * 
 * МИКРОКОНТРОЛЛЕР:
 * - ATmega168P (Arduino Nano/Uno совместимый)
 * 
 * ПИТАНИЕ:
 * - Постоянный плюс от АКБ (12В)
 * - DC-DC преобразователь 12В→5В (рекомендуется с защитой от помех)
 * - Защита: TVS-диод на входе, конденсаторы по входу и выходу
 * 
 * ПОДКЛЮЧЕНИЕ:
 * - D10 (ШИМ): управление яркостью ПТФ через MOSFET/LED-драйвер
 * - D6: управление шторкой (сервопривод/соленоид через реле)
 * - D2: сигнал габаритных огней (вход, подтяжка к GND)
 * - D4: сигнал дальнего света (вход, подтяжка к GND)
 * - D7: кнопка/тумблер ПТФ (вход, подтяжка к GND)
 * - D8: сигнал генератора/работы двигателя (вход + прерывание!)
 * - A0: датчик напряжения через делитель R1=22кОм, R2=9.98кОм
 * 
 * ВНИМАНИЕ:
 * - D8 используется как вход прерывания для пробуждения из сна
 * - Делитель напряжения ДОЛЖЕН быть откалиброван под конкретную плату
 * - При отключении сна (ENABLE_SLEEP_MODE = false) потребление ~5-15 мА
 *   что разрядит АКБ 55 Ач приблизительно за 150-450 дней
 * 
 * ═══════════════════════════════════════════════════════════════
 *                 ДИАГРАММА СОСТОЯНИЙ АВТОМАТА
 * ═══════════════════════════════════════════════════════════════
 * 
 *                    ┌─────────────────────────┐
 *                    │      STATE_OFF          │
 *                    │  (всё выключено, сон)   │
 *                    └────────────┬────────────┘
 *                                 │ двигатель запущен
 *                                 ▼
 *                    ┌─────────────────────────┐
 *                    │ STATE_ENGINE_START_WAIT │
 *                    │  (ждём 10 сек, ШИМ=0)   │
 *                    └────────────┬────────────┘
 *                         10 сек  │      │ двигатель заглушен
 *                                 ▼      ▼
 *                    ┌───────────────────────--──┐
 *                    │   STATE_DXO_ACTIVE        │◄──────-----──┐
 *                    │ (ДХО/ПТФ, яркость 70-100%)│              │
 *                    └────────────┬──────────--──┘              │
 *                                 │ двигатель заглушен          │ повторный запуск
 *                                 ▼                             │
 *                    ┌─────────────────────────┐                │
 *                    │ STATE_ENGINE_OFF_WAIT   │                │
 *                    │ (ждём N сек, свет горит)│                │
 *                    │ 10 сек / 60 сек         │                │
 *                    └────────────┬────────────┘                │
 *                          N сек  │       │ повторный запуск    │
 *                                 ▼       └──────────────────-──┘
 *                    ┌─────────────────────────┐
 *                    │    STATE_DIMMING        │
 *                    │  (плавное погасание)    │
 *                    └────────────┬────────────┘
 *                           ШИМ=0 │
 *                                 ▼
 *                    ┌─────────────────────────┐
 *                    │      STATE_OFF          │
 *                    │  (ждём 5 сек → сон)     │
 *                    └─────────────────────────┘
 */

// ============================================================
//                      ПОДКЛЮЧЕНИЕ БИБЛИОТЕК
// ============================================================

#include <GyverPWM.h>    // Расширенное управление ШИМ (частота, режимы)
#include <avr/sleep.h>   // Управление режимами сна микроконтроллера
#include <avr/power.h>   // Управление питанием периферии (экономия энергии)
#include <avr/wdt.h>     // Watchdog Timer (сторожевой таймер для сверхнадёжности)

// ============================================================
//           КОНФИГУРАЦИЯ СИСТЕМЫ (ВКЛЮЧИТЬ/ВЫКЛЮЧИТЬ)
// ============================================================
// Установите true/false для включения/отключения функций
// ВСЯ настройка системы делается ЗДЕСЬ — не нужно лезть в код!

// --- ОСНОВНЫЕ ФУНКЦИИ ---

#define ENABLE_COURTESY_LIGHT  true    // Вежливая подсветка после остановки двигателя
                                       // true = 60 секунд если были включены габариты
                                       // false = всегда 10 секунд, независимо от габаритов

#define ENABLE_ENGINE_VOLTAGE_CHECK  true  // Проверка напряжения для определения работы двигателя
                                            // true = анализировать напряжение (>13.6В = заведён)
                                            // false = только цифровой сигнал с генератора (D8)

#define ENABLE_EMERGENCY_STOP  true    // Аварийное отключение при низком напряжении (<11.5В)
                                       // true = выключать всё при разряде АКБ (рекомендуется!)
                                       // false = не отключать (опасно для АКБ — глубокий разряд!)

#define ENABLE_SHUTTER_CONTROL  true   // Управление шторкой дальнего света
                                       // true = шторка управляется автоматически
                                       // false = шторка всегда опущена (экономия пина D6)

#define ENABLE_SHUTTER_PWM_CHECK  true // Проверка яркости перед подъёмом шторки
                                       // true = шторка только при ШИМ >= 250 (защита от ослепления)
                                       // false = шторка при любой яркости (быстрее реакция)

#define ENABLE_SLEEP_MODE  true        // Режим глубокого сна для экономии АКБ
                                       // true = засыпать через 5 сек в STATE_OFF (потребление ~0.1 мкА)
                                       // false = не спать (потребление ~5-15 мА постоянно)

#define ENABLE_WATCHDOG  true          // Сторожевой таймер для автоматического перезапуска
                                       // true = перезагрузка при зависании (>8 сек без ответа)
                                       // false = без защиты от зависаний
                                       // ВНИМАНИЕ: если включён, нужно обязательно вызывать wdt_reset()

// #define DEBUG_MODE                   // Отладочный вывод в Serial Monitor
                                       //  и переведи  #define ENABLE_SLEEP_MODE  false
                                       //  раскомментируй для отладки
                                       // ВНИМАНИЕ: при DEBUG_MODE  сон не работает!
 
// ============================================================
//                 ОПРЕДЕЛЕНИЕ ПИНОВ МИКРОКОНТРОЛЛЕРА
// ============================================================

#define PIN_PWM           10   // D10: выход ШИМ для управления яркостью ПТФ
                                // Подключён к затвору MOSFET-транзистора или входу LED-драйвера
                                // Частота ШИМ: 1250 Гц (человеческий глаз не замечает мерцания)
                                // Используется таймер 1 (16 бит) для максимальной точности
                                
#define PIN_SHTORKA       6    // D6: выход управления шторкой дальнего света
                                // HIGH = шторка поднята (режим дальнего света)
                                // LOW = шторка опущена (режим ПТФ)
                                // Обычно управляет реле или сервоприводом
                                
#define PIN_GABARITS      2    // D2: вход сигнала габаритных огней
                                // HIGH = габариты включены
                                // Используется для автоматического увеличения яркости ПТФ
                                // и определения необходимости вежливой подсветки
                                
#define PIN_FARLIGHT      4    // D4: вход сигнала дальнего света
                                // HIGH = дальний свет включён
                                // Используется для управления шторкой ПТФ
                                
#define PIN_PTF_BUTTON    7    // D7: вход кнопки/тумблера ПТФ
                                // HIGH = кнопка нажата/тумблер включён
                                // Ручное управление яркостью ПТФ (100% при нажатии)
                                // Может использоваться для принудительного включения
                                
#define PIN_ENGINE_CHECK  8    // D8: вход сигнала работы двигателя/генератора
                                // Подключается к выходу "L" регулятора генератора
                                // или через оптрон к датчику давления масла
                                // HIGH = двигатель работает (генератор выдаёт напряжение)
                                // ВНИМАНИЕ: этот пин используется для пробуждения из сна!
                                // ДОЛЖЕН быть настроен как вход прерывания (PCINT0)
                                
#define PIN_VOLTAGE       A0   // Аналоговый пин A0: измерение напряжения бортсети
                                // Подключён к средней точке резистивного делителя
                                // Входное напряжение делится: Vпин = Vакб × R2/(R1+R2)
                                // Максимальное напряжение на пине: ~4.5В при 14.5В на АКБ

// ============================================================
//              ПАРАМЕТРЫ ДЕЛИТЕЛЯ НАПРЯЖЕНИЯ
// ============================================================
// ВНИМАНИЕ: эти значения критичны для точного измерения напряжения!
// При замене резисторов обязательно пересчитайте CORRECTION_FACTOR

const float DIV_R1 = 22000.0;          // Сопротивление верхнего плеча делителя в Омах
                                        // Резистор R1 подключён между +12В и аналоговым входом
                                        // Мощность резистора: не менее 0.25 Вт (при 14.5В: I=0.66мА, P=0.01Вт)
                                        // Рекомендуется использовать 1% точность
                                        
const float DIV_R2 = 9980.0;           // Сопротивление нижнего плеча делителя в Омах
                                        // Резистор R2 подключён между аналоговым входом и GND
                                        // Точное значение важно для корректного расчёта напряжения
                                        // Коэффициент деления: 22000/(22000+9980) ≈ 0.312
                                        // При 14.4В на входе: 14.4 × 0.312 ≈ 4.49В на пине
                                        
const float VREF_MV = 5113.0;          // Опорное напряжение АЦП в милливольтах
                                        // Измеряется экспериментально для конкретного экземпляра МК
                                        // Подаётся на вывод AREF или используется внутренний ИОН
                                        // Стандартное значение для ATmega168P: ~5000 мВ
                                        // Отклонение на 10 мВ даёт ошибку ~0.03В при измерении
                                        
const float CORRECTION_FACTOR = 3.25;   // Корректирующий множитель для реального напряжения
                                        // Учитывает погрешности резисторов, АЦП и наводки
                                        // ПОДБОР: измерьте напряжение мультиметром на клеммах АКБ
                                        // и сравните с показаниями в Serial Monitor
                                        // CORRECTION_FACTOR = Vмультиметр / Vмонитор
                                        // Пример: Vмультиметр=12.50, Vмонитор=12.35 → 12.50/12.35=1.012
                                        // Рекомендуется калибровать при 12.0-12.5В (двигатель заглушен)

// ============================================================
//           НАСТРАИВАЕМЫЕ ПАРАМЕТРЫ (менять здесь!)
// ============================================================
// Все временные интервалы в миллисекундах
// Для быстрой отладки можно временно уменьшить значения

// --- ЗАДЕРЖКИ (в миллисекундах) ---

const unsigned long DXO_DELAY_ON_MS = 10000;         // Задержка включения ДХО после запуска двигателя
                                                      // 10000 мс = 10 секунд
                                                      // Чтобы не слепить при запуске в тёмное время
                                                      // и не нагружать генератор сразу после старта
                                                      // Для отладки можно уменьшить до 2000 (2 сек)

const unsigned long DXO_DELAY_OFF_MS = 10000;        // Задержка выключения ПТФ после остановки двигателя
                                                      // Стандартная задержка (без габаритов)
                                                      // 10000 мс = 10 секунд

const unsigned long COURTESY_LIGHT_DELAY_MS = 30000; // Задержка выключения при вежливой подсветке
                                                      // Используется если были включены габариты
                                                      // 30000 мс = 30 секунд или сделать 1 минута
                                                      // Можно изменить: 120000 = 2 минуты, 30000 = 30 сек

const unsigned long SLEEP_TIMEOUT_MS = 60000;        // Таймаут до ухода в сон после STATE_OFF
                                                      // 60000 мс = 60 секунд (1 минута)
                                                      // Достаточно для коротких остановок
                                                      // Если двигатель не нужен >1 мин — можно спать

// --- ЯРКОСТЬ (значения ШИМ 0-255) ---

const uint8_t PWM_70_PERCENT = 180;     // Яркость в режиме ДХО (70%)
                                        // Рассчитано: 255 × 0.7 ≈ 178.5, округлено до 180
                                        // Безопасно для большинства светодиодов без радиатора
                                        // Если светодиоды греются — уменьшите до 150 (59%)

const uint8_t PWM_100_PERCENT = 255;    // Яркость в режиме ПТФ (100%)
                                        // Максимальная яркость
                                        // Требует эффективного теплоотвода!
                                        // При перегреве уменьшите до 230-240

const uint8_t PWM_OFF = 0;              // Полное выключение света
                                        // Пин принудительно прижимается к GND
                                        // для гарантированного отсутствия свечения

// --- ПЛАВНОСТЬ ИЗМЕНЕНИЯ ЯРКОСТИ ---

const uint8_t RAMP_STEP = 15;                  // Шаг изменения ШИМ за одну итерацию
                                                // Чем больше шаг — тем быстрее изменение, но менее плавно
                                                // 15 единиц = ~5.9% яркости за шаг
                                                // Полный цикл 0→255: 17 шагов × 5мс = 85 мс
                                                // Альтернативы:
                                                //   RAMP_STEP = 5  → 51 шаг × 5мс = 255 мс (очень плавно)
                                                //   RAMP_STEP = 30 → 8-9 шагов × 5мс = 40-45 мс (быстро)

const unsigned long RAMP_INTERVAL_MS = 5;       // Интервал между шагами в миллисекундах
                                                // Определяет скорость плавного изменения
                                                // 5мс даёт комфортное глазу плавное изменение
                                                // Меньше 5мс — избыточно для человеческого глаза
                                                // Больше 10мс — заметны ступеньки яркости

// --- АНТИДРЕБЕЗГ СИГНАЛОВ ---

const unsigned long ENGINE_DEBOUNCE_MS = 200;   // Время стабилизации сигнала двигателя (мс)
                                                // Сигнал должен оставаться неизменным 200 мс
                                                // чтобы считаться достоверным
                                                // Защищает от:
                                                // - дребезга контактов реле регулятора
                                                // - кратковременных провалов напряжения
                                                // - электромагнитных помех от системы зажигания

// --- АНТИДРЕБЕЗГ ШТОРКИ ---

const unsigned long SHUTTER_DELAY_MS = 100;     // Задержка перед ПОДЪЁМОМ шторки (мс)
                                                // Предотвращает дёргание при кратковременных сигналах
                                                // 100 мс — оптимально для защиты от моргания дальним
                                                
const unsigned long SHUTTER_HOLD_MS = 50;       // Задержка перед ОПУСКАНИЕМ шторки (мс)
                                                // Меньше чем подъём — безопасность важнее
                                                // Быстрое опускание при пропадании условий
                                                
const uint8_t SHUTTER_PWM_THRESHOLD = 250;      // Порог яркости для подъёма шторки (из 255)
                                                // 250/255 ≈ 98% — практически полная яркость
                                                // Компромисс между скоростью и защитой:
                                                // - 255: идеально, но может не достигаться из-за пульсаций
                                                // - 250: запас 5 единиц на флуктуации ШИМ
                                                // - 230: запас 25 единиц — быстрее, но менее безопасно

// --- ПОРОГИ НАПРЯЖЕНИЯ (Вольты) ---

const float VOLTAGE_EMERGENCY = 11.5;    // Порог аварийного отключения
                                          // Напряжение полностью разряженного АКБ под нагрузкой
                                          // 11.5В = ~20% заряда свинцово-кислотного АКБ
                                          // Дальнейший разряд приведёт к сульфатации пластин

const float VOLTAGE_ENGINE_ON = 13.6;    // Порог уверенного ЗАПУСКА двигателя
                                          // При напряжении ВЫШЕ этого значения считается
                                          // что двигатель точно запущен и генератор работает
                                          // 13.6В = типичное напряжение заряда на холостых оборотах

const float VOLTAGE_ENGINE_OFF = 12.8;   // Порог уверенной ОСТАНОВКИ двигателя
                                          // При напряжении НИЖЕ этого значения считается
                                          // что двигатель заглушен (нет зарядки от генератора)
                                          // 12.8В = полностью заряженный АКБ без нагрузки
                                          // Гистерезис: 13.6 - 12.8 = 0.8В (исключает дребезг)

// --- ПАУЗА ГЛАВНОГО ЦИКЛА ---

const unsigned long LOOP_DELAY_MS = 30;  // Пауза между итерациями loop() в миллисекундах
                                          // 30 мс = ~33 итерации в секунду
                                          // Достаточно для быстрой реакции на все события
                                          // Снижает нагрузку на процессор (нет смысла опрашивать
                                          // датчики каждый микросекунду)

// ============================================================
//           СОСТОЯНИЯ КОНЕЧНОГО АВТОМАТА
// ============================================================
// Каждое состояние — уникальная фаза работы системы
// Переходы между состояниями строго определены логикой loop()

enum SystemState : uint8_t {
  STATE_OFF,               // 0: Всё выключено, ожидание запуска или уход в сон
                            // Переходы:
                            //   → STATE_ENGINE_START_WAIT (при запуске двигателя)
                            //   → СОН (через SLEEP_TIMEOUT_MS бездействия)
                            // В этом состоянии:
                            //   - ШИМ = 0
                            //   - Шторка опущена
                            //   - Все флаги сброшены
                            
  STATE_ENGINE_START_WAIT, // 1: Двигатель запущен, идёт отсчёт задержки ДХО
                            // Переходы:
                            //   → STATE_DXO_ACTIVE (по истечении DXO_DELAY_ON_MS)
                            //   → STATE_ENGINE_OFF_WAIT (при остановке двигателя)
                            // В этом состоянии:
                            //   - ШИМ = 0 (ДХО ещё не светят)
                            //   - Отсчитывается задержка включения
                            
  STATE_DXO_ACTIVE,        // 2: Двигатель работает, ДХО/ПТФ активны
                            // Переходы:
                            //   → STATE_ENGINE_OFF_WAIT (при остановке двигателя)
                            // В этом состоянии:
                            //   - ШИМ = 70% (ДХО) или 100% (ПТФ/габариты)
                            //   - Шторка управляется по условиям
                            //   - Отслеживается включение габаритов
                            
  STATE_ENGINE_OFF_WAIT,   // 3: Двигатель заглушен, ожидание погасания
                            // Переходы:
                            //   → STATE_DIMMING (по истечении задержки)
                            //   → STATE_ENGINE_START_WAIT (при повторном запуске)
                            // В этом состоянии:
                            //   - ШИМ сохраняет последнее значение (свет горит)
                            //   - Отсчитывается задержка выключения
                            //   - Длительность зависит от gabaritsWereOn
                            
  STATE_DIMMING            // 4: Плавное погасание ШИМ до нуля
                            // Переходы:
                            //   → STATE_OFF (при достижении ШИМ = 0)
                            //   → STATE_ENGINE_START_WAIT (при повторном запуске)
                            // В этом состоянии:
                            //   - ШИМ плавно уменьшается до 0
                            //   - Шторка принудительно опущена
};

SystemState currentState = STATE_OFF;  // Текущее состояние системы при старте — всё выключено
                                        // Эта переменная — "мозг" конечного автомата
                                        // Все решения принимаются на основе её значения

// ============================================================
//                 ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ
// ============================================================

// --- Таймеры и счётчики ---

unsigned long stateTimer = 0;            // Универсальный таймер для задержек в состояниях
                                          // Хранит время (millis()) входа в текущее состояние
                                          // Используется для расчёта задержек:
                                          //   millis() - stateTimer >= нужная_задержка
                                          // Перезапускается при каждой смене состояния

unsigned long lastRampTime = 0;          // Время последнего шага плавного изменения ШИМ
                                          // Хранит значение millis() последнего изменения
                                          // Используется для контроля интервала RAMP_INTERVAL_MS
                                          // Не позволяет менять ШИМ чаще, чем раз в 5 мс

unsigned long shutterChangeTimer = 0;    // Таймер антидребезга переключения шторки
                                          // 0 = таймер неактивен (состояние стабильно)
                                          // >0 = идёт отсчёт задержки перед переключением

unsigned long sleepTimer = 0;            // Таймер до ухода в режим сна
                                          // Отсчитывает SLEEP_TIMEOUT_MS в состоянии STATE_OFF
                                          // По истечении — переход в Power-down режим

// --- Переменные ШИМ ---

uint8_t currentPWM = 0;                  // Текущее значение ШИМ (всегда отражает реальность)
                                          // Диапазон: 0-255
                                          // Это значение УЖЕ установлено на пине PIN_PWM
                                          // Обновляется ТОЛЬКО функцией updatePWM()
                                          // Никакая другая часть кода не должна менять эту переменную!

uint8_t targetPWM = 0;                   // Целевое значение ШИМ (куда нужно плавно прийти)
                                          // Диапазон: 0-255
                                          // К этому значению стремится currentPWM
                                          // Устанавливается логикой состояний

// --- Флаги состояния ---

bool engineRunning = false;              // Флаг работы двигателя (true = работает)
                                          // Это стабильное, проверенное состояние
                                          // Используется всей логикой для принятия решений
                                          // Меняется только после антидребезга и проверки напряжения

bool shutterState = false;               // Текущее физическое состояние шторки
                                          // true = поднята (HIGH), false = опущена (LOW)
                                          // Отслеживаем, чтобы не дёргать пин без необходимости

bool gabaritsWereOn = false;             // Флаг использования габаритов при работающем двигателе
                                          // true = габариты были включены → вежливая подсветка 60 сек
                                          // false = габаритов не было → стандартные 10 сек
                                          // Сбрасывается при новом запуске двигателя

bool sleepScheduled = false;             // Запланирован ли уход в режим сна
                                          // true = таймер до сна запущен (отсчитывает SLEEP_TIMEOUT_MS)
                                          // false = сон не запланирован

// --- Переменные антидребезга двигателя ---

unsigned long engineStableTimer = 0;     // Таймер стабильности сигнала двигателя
                                          // Хранит время начала текущего уровня сигнала
                                          // Сбрасывается при ЛЮБОМ изменении сигнала на PIN_ENGINE_CHECK
                                          // Если сигнал держится дольше ENGINE_DEBOUNCE_MS — он стабилен

bool lastEngineCheckSignal = false;      // Предыдущее "сырое" значение сигнала двигателя
                                          // Нужно для детектирования ФАКТА изменения сигнала
                                          // Сравнивается с текущим чтением в debounceEngineSignal()
                                          // Инициализируется при старте в setup()

bool stableEngineCheckSignal = false;    // Стабилизированное значение сигнала двигателя
                                          // Это значение гарантированно держится >200 мс
                                          // Именно оно используется в isEngineRunning()
                                          // для определения работы двигателя

// --- Переменные режима сна ---

volatile bool wokenByInterrupt = false;  // Флаг пробуждения по прерыванию
                                          // Ключевое слово volatile — переменная может измениться
                                          // в любой момент в обработчике прерывания ISR()
                                          // true = контроллер проснулся по сигналу на D8

// ============================================================
//               ОТЛАДОЧНЫЕ СТРОКИ (только DEBUG_MODE)
// ============================================================

#ifdef DEBUG_MODE
// Строки названий состояний хранятся во Flash-памяти через PROGMEM
// для экономии драгоценного SRAM (у ATmega168P всего 1024 байта SRAM!)
// Индексы соответствуют значениям SystemState (0=OFF, 1=START_WAIT, ...)

const char stateNames_0[] PROGMEM = "OFF";              // Название состояния STATE_OFF
const char stateNames_1[] PROGMEM = "START_WAIT";       // Название состояния STATE_ENGINE_START_WAIT
const char stateNames_2[] PROGMEM = "DXO_ACTIVE";       // Название состояния STATE_DXO_ACTIVE
const char stateNames_3[] PROGMEM = "OFF_WAIT";         // Название состояния STATE_ENGINE_OFF_WAIT
const char stateNames_4[] PROGMEM = "DIMMING";          // Название состояния STATE_DIMMING

// Массив указателей на строки состояний
// Используется для быстрого доступа к строке по индексу состояния
const char* const stateNames[] PROGMEM = {
  stateNames_0,  // Индекс 0 → "OFF"
  stateNames_1,  // Индекс 1 → "START_WAIT"
  stateNames_2,  // Индекс 2 → "DXO_ACTIVE"
  stateNames_3,  // Индекс 3 → "OFF_WAIT"
  stateNames_4   // Индекс 4 → "DIMMING"
};

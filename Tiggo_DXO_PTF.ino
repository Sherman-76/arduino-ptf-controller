// ============================================================
//           ОБРАБОТЧИК ПРЕРЫВАНИЯ ДЛЯ ПРОБУЖДЕНИЯ
// ============================================================

/**
 * Обработчик прерывания Pin Change Interrupt 0 (PCINT0).
 * 
 * СРАБАТЫВАЕТ: при ЛЮБОМ изменении сигнала на пинах порта B (D8-D13)
 * Мы настроили маску так, что реагирует только на D8 (PB0/PCINT0)
 * 
 * РАБОТАЕТ ДАЖЕ ВО СНЕ: это аппаратное прерывание,
 * которое пробуждает контроллер из Power-down режима
 * 
 * ЧТО ДЕЛАЕТ:
 * - Устанавливает флаг wokenByInterrupt = true
 * - Не выполняет НИКАКОЙ сложной логики (экономия времени)
 * - Основная логика обрабатывает пробуждение в loop()
 * 
 * ВНИМАНИЕ:
 * - Код в ISR должен быть МИНИМАЛЬНЫМ и БЫСТРЫМ
 * - Нельзя использовать delay(), Serial.print() и долгие операции
 * - Глобальные переменные, меняемые в ISR, должны быть volatile
 */
ISR(PCINT0_vect) {
  wokenByInterrupt = true;  // Устанавливаем флаг пробуждения
                             // Основная логика увидит его в loop()
                             // и выполнит необходимые действия после пробуждения
}

// ============================================================
//           ОБРАБОТЧИК СТОРОЖЕВОГО ТАЙМЕРА
// ============================================================

/**
 * Обработчик прерывания сторожевого таймера (Watchdog Timer).
 * 
 * НАЗНАЧЕНИЕ: защита от зависания программы
 * Если программа "зависла" и не сбрасывает таймер — 
 * watchdog перезагрузит контроллер
 * 
 * ПЕРИОД: ~8 секунд (зависит от настроек предделителя)
 * 
 * ЧТО ДЕЛАЕТ: просто подавляет сброс, позволяя использовать
 * watchdog как таймер для периодического пробуждения из сна
 */
ISR(WDT_vect) {
  // В этой версии не используем watchdog для пробуждения,
  // только для защиты от зависаний.
  // Если нужно периодическое пробуждение — можно добавить флаг здесь.
}

// ============================================================
//                  ФУНКЦИИ ЧТЕНИЯ ДАТЧИКОВ
// ============================================================

/**
 * Чтение напряжения бортсети с аналогового пина A0.
 * 
 * ПРИНЦИП РАБОТЫ:
 * 1. АЦП измеряет напряжение на пине (0-5В → 0-1023)
 * 2. Пересчитывается в реальное напряжение с учётом:
 *    - Опорного напряжения АЦП (VREF_MV = 5113 мВ)
 *    - Делителя напряжения и калибровки (CORRECTION_FACTOR = 3.25)
 * 
 * ВОЗВРАЩАЕТ:
 * - float: напряжение бортсети в Вольтах (например, 14.23)
 * 
 * ПОГРЕШНОСТЬ:
 * - ±0.05-0.1В при правильной калибровке
 * - Зависит от стабильности опорного напряжения
 * - Рекомендуется калибровать при 12.0-12.5В
 * 
 * ВРЕМЯ ВЫПОЛНЕНИЯ: ~100 мкс (микросекунд)
 */
float readVoltage() {
  // Читаем "сырое" значение АЦП (0-1023)
  // analogRead() занимает ~100 мкс при стандартной частоте АЦП
  int rawADC = analogRead(PIN_VOLTAGE);
  
  // Пересчитываем в напряжение на пине (0-5В)
  // Формула: Vпин = (rawADC × VREF_MV / 1024) / 1000
  // rawADC × VREF_MV — масштабируем в милливольты
  // / 1024.0 — преобразуем в долю от опорного (10 бит = 1024 градации)
  // / 1000.0 — переводим милливольты в вольты
  float voltageAtPin = (rawADC * VREF_MV / 1024.0) / 1000.0;
  
  // Применяем корректирующий коэффициент для получения реального напряжения
  // CORRECTION_FACTOR включает в себя и коэффициент делителя и калибровку
  float realVoltage = voltageAtPin * CORRECTION_FACTOR;
  
  // Возвращаем реальное напряжение бортсети в Вольтах
  return realVoltage;
}

// ============================================================
//                ФУНКЦИЯ АВАРИЙНОЙ ОСТАНОВКИ
// ============================================================

/**
 * Аварийное выключение всей системы при критически низком напряжении.
 * 
 * ВЫЗЫВАЕТСЯ: в каждом цикле loop() ПЕРВЫМ ДЕЛОМ (высший приоритет)
 * 
 * УСЛОВИЕ СРАБАТЫВАНИЯ:
 * - ENABLE_EMERGENCY_STOP == true (функция включена в конфигурации)
 * - voltage <= VOLTAGE_EMERGENCY (напряжение упало ниже 11.5В)
 * 
 * ЧТО ДЕЛАЕТ ПРИ СРАБАТЫВАНИИ:
 * 1. Принудительно выключает ШИМ (даже если идёт плавное изменение)
 * 2. Опускает шторку дальнего света
 * 3. Сбрасывает ВСЕ переменные состояния в начальные значения
 * 4. Переводит автомат в STATE_OFF
 * 5. Делает паузу 3 секунды для стабилизации напряжения
 * 
 * ЗАЩИТА ОТ ЛОЖНЫХ СРАБАТЫВАНИЙ:
 * - Пауза 3 сек предотвращает бесконечный цикл при пульсациях
 * - Однократное срабатывание на кратковременную просадку
 * - При затяжном разряде система останется выключенной
 */
void emergencyStop(float voltage) {
  // Проверяем, включена ли функция и нужно ли аварийно выключаться
  if (!ENABLE_EMERGENCY_STOP || voltage > VOLTAGE_EMERGENCY) return;
  
  // ========== БЛОК АВАРИЙНОГО ОТКЛЮЧЕНИЯ ==========
  
  // Принудительно устанавливаем ШИМ в 0
  PWM_set(PIN_PWM, PWM_OFF);
  
  // Дополнительно прижимаем пин ШИМ к LOW (GND)
  // Это гарантирует, что MOSFET-ключ ЗАКРЫТ и ток через светодиоды не течёт
  digitalWrite(PIN_PWM, LOW);
  
  // Опускаем шторку дальнего света
  digitalWrite(PIN_SHTORKA, LOW);
  
  // Сбрасываем текущее и целевое значения ШИМ в переменных
  currentPWM = PWM_OFF;
  targetPWM = PWM_OFF;
  
  // Сбрасываем флаг работы двигателя
  engineRunning = false;
  
  // Сбрасываем стабилизированный сигнал двигателя
  stableEngineCheckSignal = false;
  
  // Сбрасываем флаг вежливой подсветки
  gabaritsWereOn = false;
  
  // Сбрасываем состояние шторки
  shutterState = false;
  shutterChangeTimer = 0;
  
  // Отменяем запланированный сон
  sleepScheduled = false;
  
  // Переводим конечный автомат в начальное состояние
  currentState = STATE_OFF;
  
#ifdef DEBUG_MODE
  Serial.println(F("!!! EMERGENCY OFF !!!"));
#endif

  // Пауза 3 секунды для стабилизации напряжения
  delay(3000);
}

// ============================================================
//               ФУНКЦИЯ АНТИДРЕБЕЗГА СИГНАЛА
// ============================================================

/**
 * Антидребезг цифрового сигнала работы двигателя.
 * 
 * ПРОБЛЕМА:
 * - Сигнал с генератора может иметь кратковременные провалы
 * - Реле регулятора может "звенеть" при определённых нагрузках
 * - Электромагнитные помехи от системы зажигания искажают сигнал
 * - Без фильтрации это приводит к ложным срабатываниям и "морганию" света
 * 
 * РЕШЕНИЕ:
 * - Сигнал должен оставаться неизменным в течение ENGINE_DEBOUNCE_MS (200 мс)
 * - Только после этого он считается "стабильным" и используется в логике
 * - Это исключает одиночные помехи длительностью до 200 мс
 * 
 * ПАРАМЕТРЫ:
 * - rawSignal: "сырое" значение с пина PIN_ENGINE_CHECK (true/false)
 * 
 * ВОЗВРАЩАЕТ:
 * - bool: стабилизированное значение сигнала (после фильтрации)
 * 
 * ПОБОЧНЫЙ ЭФФЕКТ:
 * - Обновляет глобальную переменную stableEngineCheckSignal
 */
bool debounceEngineSignal(bool rawSignal) {
  // Получаем текущее время
  unsigned long now = millis();
  
  // Проверяем, изменился ли сигнал по сравнению с предыдущим чтением
  if (rawSignal != lastEngineCheckSignal) {
    // Сигнал изменился — сбрасываем таймер стабильности
    engineStableTimer = now;
    
    // Запоминаем новое значение как "последнее известное"
    lastEngineCheckSignal = rawSignal;
  }
  
  // Проверяем, прошло ли достаточно времени для признания сигнала стабильным
  if (now - engineStableTimer >= ENGINE_DEBOUNCE_MS) {
    // Сигнал держится дольше 200 мс — считаем его достоверным
    stableEngineCheckSignal = rawSignal;
  }
  
  // Возвращаем стабилизированное значение
  return stableEngineCheckSignal;
}

// ============================================================
//           ФУНКЦИЯ ОПРЕДЕЛЕНИЯ РАБОТЫ ДВИГАТЕЛЯ
// ============================================================

/**
 * Определение факта работы двигателя по сигналам датчиков.
 * 
 * РЕЖИМЫ РАБОТЫ (зависят от ENABLE_ENGINE_VOLTAGE_CHECK):
 * 
 * Режим 1 (ENABLE_ENGINE_VOLTAGE_CHECK = true) — ПОЛНАЯ ПРОВЕРКА:
 * - Использует и цифровой сигнал, и напряжение с гистерезисом
 * - Двигатель работает: стабильный HIGH на D8 И напряжение > 13.6В
 * - Двигатель заглушен: нет сигнала на D8 ИЛИ напряжение < 12.8В
 * - Гистерезис 0.8В исключает дребезг при граничных значениях
 * 
 * Режим 2 (ENABLE_ENGINE_VOLTAGE_CHECK = false) — ТОЛЬКО ЦИФРОВОЙ СИГНАЛ:
 * - Использует только стабильный сигнал с D8
 * - Двигатель работает: стабильный HIGH на D8
 * - Двигатель заглушен: стабильный LOW на D8
 * - Полезно при нестабильном напряжении или неоткалиброванном делителе
 * 
 * СТРАТЕГИЯ ПРИ НЕОДНОЗНАЧНОСТИ:
 * - Если условия противоречивы — сохраняется ПРЕДЫДУЩЕЕ состояние
 * - Это "серая зона" гистерезиса (для режима 1: 12.8В - 13.6В)
 * - Предотвращает метания при пограничных значениях
 * 
 * ПАРАМЕТРЫ:
 * - voltage: текущее напряжение бортсети в Вольтах
 * 
 * ВОЗВРАЩАЕТ:
 * - bool: true = двигатель работает, false = заглушен
 */
bool isEngineRunning(float voltage) {
  bool engineOff;
  bool engineOn;
  
  if (ENABLE_ENGINE_VOLTAGE_CHECK) {
    // Полная проверка: цифровой сигнал + напряжение
    engineOff = (!stableEngineCheckSignal) || (voltage < VOLTAGE_ENGINE_OFF);
    engineOn = (stableEngineCheckSignal) && (voltage > VOLTAGE_ENGINE_ON);
  } else {
    // Только цифровой сигнал (без проверки напряжения)
    engineOff = !stableEngineCheckSignal;
    engineOn = stableEngineCheckSignal;
  }
  
  // Принимаем решение на основе проверок
  if (engineOff) return false;  // Уверены, что заглушен
  if (engineOn) return true;    // Уверены, что работает
  
  // Неоднозначная ситуация — сохраняем предыдущее состояние
  return engineRunning;
}

// ============================================================
//            ФУНКЦИЯ ПЛАВНОГО УПРАВЛЕНИЯ ШИМ
// ============================================================

/**
 * ЕДИНСТВЕННАЯ функция управления яркостью через ШИМ.
 * 
 * ВАЖНО: Это единственная функция, которая меняет currentPWM!
 * Никакая другая часть кода не должна писать в currentPWM напрямую.
 * Это гарантирует целостность управления яркостью.
 * 
 * ПРИНЦИП:
 * - Плавно изменяет currentPWM в сторону targetPWM
 * - За один вызов может изменить ШИМ максимум на RAMP_STEP (15)
 * - Соблюдает интервал RAMP_INTERVAL_MS (5 мс) между изменениями
 * 
 * ОПТИМИЗАЦИЯ:
 * - Если currentPWM == targetPWM — мгновенный выход (самый частый случай)
 * - Не использует delay() — не блокирует выполнение программы
 * - Работает через проверку millis() (неблокирующий таймер)
 * 
 * БЕЗОПАСНОСТЬ:
 * - При достижении ШИМ=0 принудительно прижимает пин к GND
 * - Это предотвращает паразитное свечение светодиодов
 * - Даже при ШИМ=0 таймер может генерировать короткие импульсы
 */
void updatePWM() {
  // Если текущее значение уже равно целевому — ничего не делаем
  // Это САМЫЙ ЧАСТЫЙ случай (когда яркость не нужно менять)
  if (currentPWM == targetPWM) {
    // Дополнительная проверка: если ШИМ = 0, гарантируем низкий уровень на пине
    // Это защита от паразитного свечения светодиодов
    if (currentPWM == 0) {
      digitalWrite(PIN_PWM, LOW);
    }
    return;  // Выходим — цель достигнута, менять нечего
  }
  
  // Получаем текущее время для проверки интервала
  unsigned long now = millis();
  
  // Проверяем, прошло ли 5 мс с последнего изменения
  // Если нет — выходим, ждём следующего вызова loop()
  if (now - lastRampTime < RAMP_INTERVAL_MS) return;
  
  // Обновляем время последнего изменения
  // Теперь следующие 5 мс изменения не будет
  lastRampTime = now;
  
  // ===== ИЗМЕНЯЕМ ЯРКОСТЬ НА ОДИН ШАГ =====
  
  if (currentPWM < targetPWM) {
    // Случай 1: нужно УВЕЛИЧИТЬ яркость
    // Проверяем, не превысит ли шаг целевое значение
    if (currentPWM + RAMP_STEP > targetPWM) {
      // Если превысит — устанавливаем точно в цель
      currentPWM = targetPWM;
    } else {
      // Если не превысит — добавляем шаг
      currentPWM = currentPWM + RAMP_STEP;
    }
  } else {
    // Случай 2: нужно УМЕНЬШИТЬ яркость
    // Проверяем, не станет ли значение ниже целевого
    if (currentPWM - RAMP_STEP < targetPWM) {
      // Если станет ниже — устанавливаем точно в цель
      currentPWM = targetPWM;
    } else {
      // Если не станет — вычитаем шаг
      currentPWM = currentPWM - RAMP_STEP;
    }
  }
  
  // Применяем новое значение ШИМ к пину
  PWM_set(PIN_PWM, currentPWM);
  
  // Если достигли нуля — принудительно прижимаем пин к GND
  if (currentPWM == 0) {
    digitalWrite(PIN_PWM, LOW);
  }
}

// ============================================================
//             ФУНКЦИЯ УПРАВЛЕНИЯ ШТОРКОЙ
// ============================================================

/**
 * Управление шторкой дальнего света ПТФ с антидребезгом.
 * 
 * РЕЖИМЫ РАБОТЫ (зависят от конфигурации):
 * 
 * РЕЖИМ 1 (ENABLE_SHUTTER_CONTROL = true):
 * - Шторка управляется автоматически по условиям
 * - Дополнительные проверки если ENABLE_SHUTTER_PWM_CHECK = true
 * 
 * РЕЖИМ 2 (ENABLE_SHUTTER_CONTROL = false):
 * - Шторка всегда опущена (экономия пина D6)
 * - Пин принудительно удерживается в LOW
 * 
 * УСЛОВИЯ ПОДЪЁМА (все должны выполняться одновременно):
 * 1. Двигатель работает (engineRunning == true)
 * 2. Габариты ИЛИ кнопка ПТФ активны
 * 3. Дальний свет включён
 * 4. Яркость >= SHUTTER_PWM_THRESHOLD (если ENABLE_SHUTTER_PWM_CHECK = true)
 * 
 * АНТИДРЕБЕЗГ:
 * - Подъём: задержка SHUTTER_DELAY_MS (100 мс) — защита от моргания
 * - Опускание: задержка SHUTTER_HOLD_MS (50 мс) — быстрое выключение
 * - Если во время задержки условия изменились — таймер сбрасывается
 */
void updateShutter(bool ptfButton, bool gabarits, bool farLight) {
  // Если управление шторкой отключено в конфигурации — всегда опущена
  if (!ENABLE_SHUTTER_CONTROL) {
    if (shutterState) {
      // Шторка была поднята — опускаем
      digitalWrite(PIN_SHTORKA, LOW);
      shutterState = false;
      shutterChangeTimer = 0;
    }
    return;
  }
  
  // Проверяем условие яркости
  // Если проверка включена — яркость должна быть >= порога
  // Если проверка отключена — условие всегда истинно
  bool brightnessOk = ENABLE_SHUTTER_PWM_CHECK ? (currentPWM >= SHUTTER_PWM_THRESHOLD) : true;
  
  // Вычисляем, должны ли мы сейчас поднять шторку
  bool shouldBeUpNow = (engineRunning &&                    // Двигатель работает
                        (ptfButton || gabarits) &&          // ПТФ или габариты
                        farLight &&                         // Дальний свет
                        brightnessOk);                      // Яркость достаточна
  
  unsigned long now = millis();
  
  // Проверяем, совпадает ли желаемое состояние с текущим
  if (shouldBeUpNow != shutterState) {
    // Состояние должно измениться
    
    // Если таймер ещё не запущен — запускаем
    if (shutterChangeTimer == 0) {
      shutterChangeTimer = now;
    }
    
    // Вычисляем, сколько времени условия не совпадают
    unsigned long elapsed = now - shutterChangeTimer;
    
    // Выбираем задержку в зависимости от направления:
    // Подъём — дольше (защита от моргания)
    // Опускание — быстрее (безопасность)
    unsigned long requiredDelay = shouldBeUpNow ? SHUTTER_DELAY_MS : SHUTTER_HOLD_MS;
    
    // Если задержка истекла — выполняем переключение
    if (elapsed >= requiredDelay) {
      digitalWrite(PIN_SHTORKA, shouldBeUpNow ? HIGH : LOW);
      shutterState = shouldBeUpNow;
      shutterChangeTimer = 0;  // Сбрасываем таймер
      
#ifdef DEBUG_MODE
      Serial.print(F(" | Шторка: "));
      Serial.print(shutterState ? F("ON") : F("OFF"));
#endif
    }
    // Если задержка не истекла — ждём
    
  } else {
    // Состояние совпадает — сбрасываем таймер если был запущен
    // Это "прощает" кратковременные нарушения условий
    if (shutterChangeTimer != 0) {
      shutterChangeTimer = 0;
    }
  }
}

// ============================================================
//            ФУНКЦИИ УПРАВЛЕНИЯ РЕЖИМОМ СНА
// ============================================================

/**
 * Настройка сторожевого таймера (Watchdog Timer).
 * 
 * ВАРИАНТЫ ИСПОЛЬЗОВАНИЯ:
 * 
 * 1. Режим защиты от зависания (ENABLE_WATCHDOG = true):
 *    - Если программа зависла и не вызывает wdt_reset() >8 сек — перезагрузка
 *    - Надёжная защита от сбоев в дороге
 * 
 * 2. Режим периодического пробуждения (дополнительно):
 *    - Можно настроить на пробуждение каждые 8 сек для проверки АКБ
 *    - В текущей версии НЕ ИСПОЛЬЗУЕТСЯ для пробуждения
 *    - Пробуждение только по Pin Change Interrupt на D8
 * 
 * НАСТРОЙКА:
 * - Предделитель: 256 (самый большой интервал)
 * - Период срабатывания: ~8 секунд при тактовой частоте 16 МГц
 */
void setupWatchdog() {
  if (!ENABLE_WATCHDOG) return;
  
  // Сбрасываем watchdog перед настройкой
  wdt_reset();
  
  // Очищаем регистр управления watchdog
  MCUSR &= ~(1 << WDRF);
  
  // Настраиваем watchdog:
  // WDTCSR — Watchdog Timer Control and Status Register
  // WDCE — Watchdog Change Enable (разрешить изменение)
  // WDE — Watchdog Enable (включить watchdog)
  WDTCSR |= (1 << WDCE) | (1 << WDE);
  
  // Устанавливаем режим и предделитель:
  // WDIE — Watchdog Interrupt Enable (режим прерывания, не сброса!)
  // WDP3,WDP2,WDP1,WDP0 = 1,0,0,1 — предделитель 256 → ~8 сек
  // При зависании вызовет прерывание, а не мгновенный сброс
  WDTCSR = (1 << WDIE) | (1 << WDP3) | (1 << WDP0);
  
  // Теперь watchdog работает в режиме прерывания
  // Если программа зависнет — через 8 сек вызовется ISR(WDT_vect)
  // и произойдёт перезагрузка контроллера
}

/**
 * Настройка прерывания для пробуждения из сна.
 * 
 * ИСПОЛЬЗУЕТ: Pin Change Interrupt на порту B (PCINT0)
 * 
 * ПРИНЦИП:
 * - Пин D8 (PB0) на ATmega168P подключён к PCINT0
 * - Прерывание срабатывает при ЛЮБОМ изменении сигнала
 * - Это пробуждает контроллер из Power-down режима
 * 
 * КОНФИГУРАЦИЯ:
 * - PCIE0: разрешить прерывания от порта B
 * - PCINT0: маска — реагировать только на пин PB0 (D8)
 */
void setupWakeUpInterrupt() {
  // Разрешаем Pin Change Interrupt для порта B
  // PCICR — Pin Change Interrupt Control Register
  // PCIE0 — Pin Change Interrupt Enable для порта B
  PCICR |= (1 << PCIE0);
  
  // Выбираем пин PB0 (D8) для прерывания
  // PCMSK0 — Pin Change Mask Register 0 (для порта B)
  // PCINT0 — пин PB0 (Arduino D8)
  PCMSK0 |= (1 << PCINT0);
  
  // Сбрасываем флаг пробуждения
  wokenByInterrupt = false;
}

/**
 * Подготовка и вход в режим глубокого сна (Power-down).
 * 
 * Power-down — самый экономичный режим:
 * - Потребление: ~0.1 мкА (практически ничего!)
 * - Останавливается всё: ЦПУ, таймеры, АЦП, перифирия
 * - Продолжают работать: внешние прерывания, watchdog
 * 
 * ПОСЛЕ ПРОБУЖДЕНИЯ:
 * - Все регистры периферии СБРОШЕНЫ
 * - Необходима ПОЛНАЯ переинициализация: ШИМ, пины, Serial
 * - Микроконтроллер начнёт выполнение со СЛЕДУЮЩЕЙ после sleep_cpu() инструкции
 * 
 * ПРОЦЕСС ВХОДА В СОН:
 * 1. Настройка прерывания для пробуждения (пин D8)
 * 2. Отключение АЦП для экономии энергии
 * 3. Проверка: не произошло ли прерывание прямо сейчас
 * 4. Если нет — атомарный вход в сон (sleep_cpu)
 * 5. После пробуждения — восстановление всей периферии
 */
void enterSleep() {
#ifdef DEBUG_MODE
  Serial.println(F(">>> Уход в сон (Power-down)"));
  Serial.flush();  // Ждём завершения передачи всех данных
  delay(100);      // Даём время на физическую отправку по UART
#endif
  
  // Настраиваем прерывание для пробуждения (если ещё не настроено)
  setupWakeUpInterrupt();
  
  // Устанавливаем режим сна: Power-down (самый глубокий)
  // SMCR — Sleep Mode Control Register
  // SM1=1, SM0=0 → SLEEP_MODE_PWR_DOWN
  set_sleep_mode(SLEEP_MODE_PWR_DOWN);
  
  // Отключаем АЦП для дополнительной экономии энергии
  // Во сне он всё равно не работает
  ADCSRA &= ~(1 << ADEN);
  
  // Разрешаем сон (устанавливаем бит SE в SMCR)
  sleep_enable();
  
  // КРИТИЧЕСКАЯ СЕКЦИЯ: отключаем прерывания для атомарной проверки
  noInterrupts();
  
  // Проверяем, не произошло ли прерывание прямо сейчас
  if (!wokenByInterrupt) {
    // Прерываний не было — можно спать
    // sleep_cpu() атомарно разрешает прерывания и засыпает
    // Это гарантирует, что мы не пропустим прерывание между проверкой и сном
    interrupts();
    sleep_cpu();
    // ═══════════════════════════════════════════════════════
    // Код продолжит выполнение ЗДЕСЬ после пробуждения!
    // ═══════════════════════════════════════════════════════
  } else {
    // Прерывание произошло прямо перед сном — не засыпаем
    interrupts();
  }
  
  // После пробуждения (или отмены сна):
  sleep_disable();  // Запрещаем сон для нормальной работы
  
  // Восстанавливаем АЦП (был отключён для экономии)
  ADCSRA |= (1 << ADEN);
  
  // Переинициализируем ШИМ (регистры таймеров сбросились во сне)
  PWM_frequency(PIN_PWM, 1250, FAST_PWM);
  PWM_set(PIN_PWM, currentPWM);
  
  // Восстанавливаем состояние пинов (Mode и Output)
  pinMode(PIN_SHTORKA, OUTPUT);
  digitalWrite(PIN_SHTORKA, shutterState ? HIGH : LOW);
  
  // Переинициализируем watchdog если был включён
  if (ENABLE_WATCHDOG) {
    setupWatchdog();
  }
  
  // Сбрасываем все таймеры для корректной работы после пробуждения
  // millis() может показывать некорректное время после сна,
  // но для относительных задержек это не критично
  stateTimer = millis();
  lastRampTime = millis();
  engineStableTimer = millis();
  shutterChangeTimer = 0;
  sleepScheduled = false;
  
  // Инициализируем антидребезг заново
  lastEngineCheckSignal = digitalRead(PIN_ENGINE_CHECK);
  stableEngineCheckSignal = lastEngineCheckSignal;
  
#ifdef DEBUG_MODE
  Serial.begin(9600);  // Переинициализируем Serial после сна
  delay(100);
  Serial.println(F(">>> Пробуждение из сна"));
#endif
}

// ============================================================
//                 ФУНКЦИЯ ОТЛАДОЧНОГО ВЫВОДА
// ============================================================

#ifdef DEBUG_MODE
/**
 * Вывод отладочной информации в Serial Monitor.
 * 
 * ВЫВОДИТ В ОДНУ СТРОКУ:
 * - U=напряжение (В, 2 знака после запятой)
 * - G=габариты (Y/N)
 * - D=дальний (Y/N)
 * - P=кнопка ПТФ (Y/N)
 * - Gen=сигнал генератора (Y/N)
 * - Eng=двигатель работает (Y/N)
 * - G-Was=габариты были включены (Y/N)
 * - St=текущее состояние автомата
 * 
 * ВСЕ строки используют макрос F() для хранения во Flash-памяти.
 * Это критически важно для ATmega168P (всего 1024 байта SRAM).
 * 
 * ВНИМАНИЕ:
 * - Вывод занимает ~5-10 мс при скорости 9600 бод
 * - НЕ РАБОТАЕТ во время сна (Serial отключается)
 * - В финальной прошивке должен быть ОТКЛЮЧЁН
 */
void printDebug(float voltage, bool gabarits, bool farLight, bool ptfButton, bool engineRaw) {
  Serial.print(F("U="));
  Serial.print(voltage, 2);
  Serial.print(F("V G:"));
  Serial.print(gabarits ? 'Y' : 'N');
  Serial.print(F(" D:"));
  Serial.print(farLight ? 'Y' : 'N');
  Serial.print(F(" P:"));
  Serial.print(ptfButton ? 'Y' : 'N');
  Serial.print(F(" Gen:"));
  Serial.print(engineRaw ? 'Y' : 'N');
  Serial.print(F(" Eng:"));
  Serial.print(engineRunning ? 'Y' : 'N');
  Serial.print(F(" G-Was:"));
  Serial.print(gabaritsWereOn ? 'Y' : 'N');
  Serial.print(F(" St:"));
  Serial.print((const __FlashStringHelper*)pgm_read_ptr(&stateNames[currentState]));
}
#endif

// ============================================================
//                 ФУНКЦИЯ ИНИЦИАЛИЗАЦИИ SETUP
// ============================================================

/**
 * Инициализация системы при включении питания.
 * Выполняется ОДИН РАЗ при старте микроконтроллера.
 * 
 * ПОРЯДОК ИНИЦИАЛИЗАЦИИ:
 * 1. Настройка сторожевого таймера (если включён)
 * 2. Настройка режимов пинов (вход/выход)
 * 3. Настройка ШИМ (частота 1250 Гц, начальное значение 0)
 * 4. Установка начальных состояний выходов
 * 5. Инициализация Serial для отладки (если включена)
 * 6. Первичное чтение сигналов для антидребезга
 */
void setup() {
  // ===== СТОРОЖЕВОЙ ТАЙМЕР =====
  // Настраиваем до всего остального для защиты с самого начала
  setupWatchdog();
  
  // ===== НАСТРОЙКА РЕЖИМОВ ПИНОВ =====
  
  // Входы: настраиваем пины как INPUT (высокое входное сопротивление)
  pinMode(PIN_GABARITS, INPUT);      // Сигнал габаритных огней
  pinMode(PIN_FARLIGHT, INPUT);      // Сигнал дальнего света
  pinMode(PIN_PTF_BUTTON, INPUT);    // Кнопка/тумблер ПТФ
  pinMode(PIN_ENGINE_CHECK, INPUT);  // Сигнал работы двигателя (КРИТИЧЕН для пробуждения!)
  
  // Выходы: настраиваем пины как OUTPUT
  pinMode(PIN_SHTORKA, OUTPUT);      // Управление шторкой
  pinMode(PIN_PWM, OUTPUT);          // ШИМ управления яркостью
  
  // ===== НАСТРОЙКА ШИМ =====
  
  // Устанавливаем частоту ШИМ 1250 Гц в быстром режиме
  // Частота выше 1000 Гц незаметна для человеческого глаза
  // FAST_PWM — минимальная задержка между изменением регистра и выходом
  PWM_frequency(PIN_PWM, 1250, FAST_PWM);
  
  // Начальное значение ШИМ = 0 (свет выключен)
  PWM_set(PIN_PWM, PWM_OFF);
  
  // ===== НАЧАЛЬНЫЕ СОСТОЯНИЯ ВЫХОДОВ =====
  
  digitalWrite(PIN_SHTORKA, LOW);   // Шторка опущена
  digitalWrite(PIN_PWM, LOW);       // ШИМ принудительно в 0 (дублирование для надёжности)
  
  // Инициализация переменных состояния шторки
  shutterState = false;
  shutterChangeTimer = 0;
  
  // ===== ИНИЦИАЛИЗАЦИЯ ПЕРЕМЕННЫХ =====
  
  gabaritsWereOn = false;           // Габариты не были включены
  sleepScheduled = false;           // Сон не запланирован
  wokenByInterrupt = false;         // Пробуждения не было
  
  // ===== ИНИЦИАЛИЗАЦИЯ ОТЛАДКИ =====
  
#ifdef DEBUG_MODE
  Serial.begin(9600);
  Serial.println(F("=== ПТФ v22.1 (АКБ + сон + watchdog) ==="));
  Serial.println(F("Конфигурация:"));
  Serial.print(F("  Вежливая подсветка: "));
  Serial.println(ENABLE_COURTESY_LIGHT ? F("ВКЛ") : F("ВЫКЛ"));
  Serial.print(F("  Проверка напряжения: "));
  Serial.println(ENABLE_ENGINE_VOLTAGE_CHECK ? F("ВКЛ") : F("ВЫКЛ"));
  Serial.print(F("  Аварийная защита: "));
  Serial.println(ENABLE_EMERGENCY_STOP ? F("ВКЛ") : F("ВЫКЛ"));
  Serial.print(F("  Управление шторкой: "));
  Serial.println(ENABLE_SHUTTER_CONTROL ? F("ВКЛ") : F("ВЫКЛ"));
  Serial.print(F("  Проверка яркости шторки: "));
  Serial.println(ENABLE_SHUTTER_PWM_CHECK ? F("ВКЛ") : F("ВЫКЛ"));
  Serial.print(F("  Режим сна: "));
  Serial.println(ENABLE_SLEEP_MODE ? F("ВКЛ") : F("ВЫКЛ"));
  Serial.print(F("  Watchdog: "));
  Serial.println(ENABLE_WATCHDOG ? F("ВКЛ") : F("ВЫКЛ"));
#endif

  // ===== ИНИЦИАЛИЗАЦИЯ АНТИДРЕБЕЗГА =====
  
  // Читаем текущее состояние пина генератора
  lastEngineCheckSignal = digitalRead(PIN_ENGINE_CHECK);
  
  // Инициализируем стабилизированный сигнал тем же значением
  stableEngineCheckSignal = lastEngineCheckSignal;
  
  // Устанавливаем таймер стабильности на текущее время
  engineStableTimer = millis();
}

// ============================================================
//                  ГЛАВНЫЙ ЦИКЛ ПРОГРАММЫ
// ============================================================

/**
 * Главный цикл — выполняется бесконечно после setup().
 * 
 * Частота выполнения: ~33 раза в секунду (при LOOP_DELAY_MS = 30)
 * Каждая итерация занимает: ~30 мс (включая паузу)
 * 
 * СТРУКТУРА ЦИКЛА:
 * 1. Сброс сторожевого таймера (если включён)
 * 2. Сбор данных со всех датчиков
 * 3. Антидребезг критических сигналов
 * 4. Определение работы двигателя
 * 5. Аварийная проверка (высший приоритет)
 * 6. Обновление флага габаритов
 * 7. Определение переходов между состояниями
 * 8. Выполнение логики текущего состояния (конечный автомат)
 * 9. Управление шторкой
 * 10. Отладка (если включена)
 * 11. Пауза LOOP_DELAY_MS
 */
void loop() {
  // ============================================================
  // ШАГ 0: СБРОС СТОРОЖЕВОГО ТАЙМЕРА
  // ============================================================
  
  // Если watchdog включён — сообщаем ему что программа "жива"
  // Если не вызвать wdt_reset() в течение ~8 сек — произойдёт перезагрузка
  if (ENABLE_WATCHDOG) {
    wdt_reset();
  }
  
  // ============================================================
  // ШАГ 1: СБОР ДАННЫХ СО ВСЕХ ДАТЧИКОВ
  // ============================================================
  
  float voltage = readVoltage();                                     // Напряжение бортсети
  bool gabarits = (digitalRead(PIN_GABARITS) == HIGH);              // Габаритные огни
  bool farLight = (digitalRead(PIN_FARLIGHT) == HIGH);              // Дальний свет фар
  bool ptfButton = (digitalRead(PIN_PTF_BUTTON) == HIGH);           // Кнопка ПТФ
  bool engineCheckRaw = (digitalRead(PIN_ENGINE_CHECK) == HIGH);    // Сигнал генератора (сырой)
  
  // ============================================================
  // ШАГ 2: АНТИДРЕБЕЗГ СИГНАЛА ДВИГАТЕЛЯ
  // ============================================================
  
  debounceEngineSignal(engineCheckRaw);
  
  // ============================================================
  // ШАГ 3: ОПРЕДЕЛЕНИЕ РАБОТЫ ДВИГАТЕЛЯ
  // ============================================================
  
  engineRunning = isEngineRunning(voltage);
  
  // ============================================================
  // ШАГ 4: ОТЛАДОЧНЫЙ ВЫВОД (если DEBUG_MODE включён)
  // ============================================================
  
#ifdef DEBUG_MODE
  printDebug(voltage, gabarits, farLight, ptfButton, engineCheckRaw);
#endif
  
  // ============================================================
  // ШАГ 5: АВАРИЙНАЯ ПРОВЕРКА (ВЫСШИЙ ПРИОРИТЕТ)
  // ============================================================
  
  emergencyStop(voltage);
  
  // Если после emergencyStop система в STATE_OFF И напряжение всё ещё низкое —
  // пропускаем остальную логику (нет смысла работать при аварийном напряжении)
  if (currentState == STATE_OFF && voltage <= VOLTAGE_EMERGENCY) {
    delay(LOOP_DELAY_MS);
    return;
  }
  
  // ============================================================
  // ШАГ 6: ОБНОВЛЕНИЕ ФЛАГА ИСПОЛЬЗОВАНИЯ ГАБАРИТОВ
  // ============================================================
  
  // Запоминаем, что габариты были включены при работающем двигателе
  // Это нужно для определения режима вежливой подсветки
  if (engineRunning && (currentState == STATE_DXO_ACTIVE || currentState == STATE_ENGINE_START_WAIT)) {
    if (gabarits) {
      gabaritsWereOn = true;
    }
  }
  
    // ============================================================
  // ШАГ 7: ОПРЕДЕЛЕНИЕ ПЕРЕХОДОВ МЕЖДУ СОСТОЯНИЯМИ
  // ============================================================
  
  unsigned long now = millis();
  
  // ----- Переход: ДВИГАТЕЛЬ ЗАПУСТИЛСЯ -----
  // Условие: двигатель работает И мы не в активном режиме
  if (engineRunning && currentState != STATE_ENGINE_START_WAIT && currentState != STATE_DXO_ACTIVE) {
    
    // ВАЖНО: проверяем, КАК мы сюда попали
    if (currentState == STATE_ENGINE_OFF_WAIT || currentState == STATE_DIMMING) {
      // Случай 1: ВРЕМЕННОЕ ПРОПАДАНИЕ СИГНАЛА
      // Двигатель работал, сигнал кратковременно пропал, и теперь вернулся
      // НЕ сбрасываем яркость — сразу возвращаемся в активный режим!
#ifdef DEBUG_MODE
      Serial.println(F("\n>>> Сигнал восстановлен — возврат в DXO_ACTIVE"));
#endif
      currentState = STATE_DXO_ACTIVE;
      // Восстанавливаем яркость по текущим условиям (а не в 0!)
      targetPWM = (ptfButton || gabarits) ? PWM_100_PERCENT : PWM_70_PERCENT;
      lastRampTime = now;
      // Отменяем запланированный сон
      sleepScheduled = false;
      
    } else {
      // Случай 2: НОРМАЛЬНЫЙ ЗАПУСК ДВИГАТЕЛЯ
      // Система была в STATE_OFF — это реальный запуск
#ifdef DEBUG_MODE
      Serial.print(F("\n>>> Eng ON, wait "));
      Serial.print(DXO_DELAY_ON_MS / 1000);
      Serial.println(F("s"));
#endif
      currentState = STATE_ENGINE_START_WAIT;
      stateTimer = now;
      targetPWM = PWM_OFF;  // Свет выключен — ждём задержку
      lastRampTime = now;
      // Сбрасываем флаг вежливой подсветки при новом запуске
      gabaritsWereOn = false;
      // Отменяем запланированный сон
      sleepScheduled = false;
    }
  }
  
  // ----- Переход: ДВИГАТЕЛЬ ЗАГЛУШЕН -----
  // Условие: двигатель НЕ работает И состояние было активным
  if (!engineRunning && (currentState == STATE_ENGINE_START_WAIT || currentState == STATE_DXO_ACTIVE)) {
    
#ifdef DEBUG_MODE
    if (ENABLE_COURTESY_LIGHT && gabaritsWereOn) {
      Serial.print(F("\n>>> Eng OFF (ГАБАРИТЫ БЫЛИ ВКЛ), wait "));
      Serial.print(COURTESY_LIGHT_DELAY_MS / 1000);
      Serial.println(F("s"));
    } else {
      Serial.print(F("\n>>> Eng OFF, wait "));
      Serial.print(DXO_DELAY_OFF_MS / 1000);
      Serial.println(F("s"));
    }
#endif
    
    currentState = STATE_ENGINE_OFF_WAIT;
    stateTimer = now;
    // ВАЖНО: targetPWM НЕ меняем — свет продолжает гореть
    // с той же яркостью, что и до остановки двигателя!
    // Это реализует функцию "вежливого света"
  }
  
  // ============================================================
  // ШАГ 8: ЛОГИКА ТЕКУЩЕГО СОСТОЯНИЯ (КОНЕЧНЫЙ АВТОМАТ)
  // ============================================================
  
  switch (currentState) {
    
    // ============================================================
    // Состояние STATE_OFF: Всё выключено
    // Система ждёт запуска двигателя или уходит в сон
    // ============================================================
    case STATE_OFF:
      targetPWM = PWM_OFF;
      updatePWM();
      digitalWrite(PIN_SHTORKA, LOW);
      shutterState = false;
      
      // Планируем уход в сон (если режим сна включён)
      if (!sleepScheduled) {
        sleepScheduled = true;
        sleepTimer = now;
#ifdef DEBUG_MODE
        if (ENABLE_SLEEP_MODE) {
          Serial.print(F(" | Сон через "));
          Serial.print(SLEEP_TIMEOUT_MS / 1000);
          Serial.print(F(" сек..."));
        } else {
          Serial.print(F(" | Сон отключён"));
        }
#endif
      }
      
      // Проверяем, пора ли спать
      if (sleepScheduled && (now - sleepTimer >= SLEEP_TIMEOUT_MS)) {
        if (!engineRunning && !stableEngineCheckSignal) {
          if (ENABLE_SLEEP_MODE) {
            enterSleep();
            return;  // Пропускаем текущую итерацию
          } else {
            // Сон отключён — просто сбрасываем таймер
            sleepScheduled = false;
          }
        }
      }
      break;
      
    // ============================================================
    // Состояние STATE_ENGINE_START_WAIT: Ожидание включения ДХО
    // Двигатель работает, но свет ещё не горит
    // ============================================================
    case STATE_ENGINE_START_WAIT:
      updatePWM();
      
      if (now - stateTimer >= DXO_DELAY_ON_MS) {
#ifdef DEBUG_MODE
        Serial.println(F("\n>>> DXO ACTIVE"));
#endif
        currentState = STATE_DXO_ACTIVE;
        targetPWM = (ptfButton || gabarits) ? PWM_100_PERCENT : PWM_70_PERCENT;
        lastRampTime = now;
      }
      break;
      
    // ============================================================
    // Состояние STATE_DXO_ACTIVE: ДХО/ПТФ активны
    // Двигатель работает, свет горит
    // ============================================================
    case STATE_DXO_ACTIVE:
      {
        uint8_t desiredPWM = (ptfButton || gabarits) ? PWM_100_PERCENT : PWM_70_PERCENT;
        if (targetPWM != desiredPWM) {
          targetPWM = desiredPWM;
          lastRampTime = now;
        }
        updatePWM();
      }
      break;
      
    // ============================================================
    // Состояние STATE_ENGINE_OFF_WAIT: Ожидание погасания
    // Двигатель заглушен, свет пока горит
    // ============================================================
    case STATE_ENGINE_OFF_WAIT:
      updatePWM();
      
      {
        // Выбираем задержку: вежливая подсветка или стандартная
        unsigned long offDelay = (ENABLE_COURTESY_LIGHT && gabaritsWereOn) 
                                  ? COURTESY_LIGHT_DELAY_MS 
                                  : DXO_DELAY_OFF_MS;
        
        if (now - stateTimer >= offDelay) {
#ifdef DEBUG_MODE
          Serial.println(F("\n>>> DIMMING start"));
#endif
          currentState = STATE_DIMMING;
          targetPWM = PWM_OFF;
          lastRampTime = now;
        }
      }
      break;
      
    // ============================================================
    // Состояние STATE_DIMMING: Плавное погасание
    // ШИМ уменьшается от текущего значения до 0
    // ============================================================
    case STATE_DIMMING:
      updatePWM();
      
      if (currentPWM == PWM_OFF) {
#ifdef DEBUG_MODE
        Serial.println(F("\n>>> FULL OFF"));
#endif
        currentState = STATE_OFF;
        digitalWrite(PIN_SHTORKA, LOW);
        shutterState = false;
        
        // Сбрасываем флаг габаритов после завершения погасания
        gabaritsWereOn = false;
        
        // Запускаем таймер до сна
        sleepScheduled = true;
        sleepTimer = now;
      }
      break;
  }
  
  // ============================================================
  // ШАГ 9: УПРАВЛЕНИЕ ШТОРКОЙ (всегда, независимо от состояния)
  // ============================================================
  
  updateShutter(ptfButton, gabarits, farLight);
  
  // ============================================================
  // ШАГ 10: ЗАВЕРШЕНИЕ ИТЕРАЦИИ
  // ============================================================
  
#ifdef DEBUG_MODE
  Serial.println();
#endif

  delay(LOOP_DELAY_MS);
}
